# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: claude | openai | gemini
LLM_PROVIDER=claude

# ── API Keys (only the one you use needs to be filled) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...        # preferred — AI Studio key (aistudio.google.com)
# GOOGLE_API_KEY=AIza...     # fallback — but GCP Console keys have no free quota

# ── Model overrides (optional — defaults shown) ───────────────────────────────
# CLAUDE_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o-mini
# GEMINI_MODEL=gemini-2.0-flash-lite
